# =============================================================================
# SilvaEngine Gateway — Test Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values for integration testing:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env with real credentials to version control.
# =============================================================================

# ── Auth ──────────────────────────────────────────────────────────────────────
GATEWAY_AUTH_PROVIDER=local          # local | cognito
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP=15                  # Token expiry in minutes
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# ADMIN_STATIC_TOKEN=                 # Optional: pre-generated permanent token

# ── Local user file (optional, local auth only) ──────────────────────────────
# LOCAL_USER_FILE=                    # Path to users.json

# ── AWS Cognito (only if GATEWAY_AUTH_PROVIDER=cognito) ───────────────────────
# COGNITO_USER_POOL_ID=
# COGNITO_APP_CLIENT_ID=
# COGNITO_APP_SECRET=
# COGNITO_JWKS_URL=                  # Optional: auto-derived from pool ID

# ── Gateway server ───────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8765
GATEWAY_WORKERS=1

# ── Performance tuning ───────────────────────────────────────────────────────
# Thread pool size for synchronous dispatch execution (WebSocket handlers, etc.)
GATEWAY_DISPATCH_WORKERS=32

# ── Route manifest (optional overrides) ──────────────────────────────────────
# GATEWAY_ROUTES_CONFIG_PATH=        # Path to custom routes.yaml

# ── Shared-store backends (required when GATEWAY_WORKERS > 1) ─────────────────
GATEWAY_TASK_BACKEND=memory          # memory | dynamodb
# GATEWAY_TASK_TABLE=silvaengine-gateway-tasks       # DynamoDB hash key: task_id
GATEWAY_TASK_TTL=3600                # Task state TTL (seconds)
GATEWAY_RATE_LIMIT_BACKEND=memory    # memory | dynamodb
# GATEWAY_RATE_LIMIT_TABLE=silvaengine-gateway-ratelimit  # hash key: rl_key
# NOTE: SSE with workers>1 needs sticky sessions; cross-worker broadcast needs
# a pub/sub backplane (not provided). See docs/gateway_setup.md.

# ── Tenant ───────────────────────────────────────────────────────────────────
endpoint_id=gpt
part_id=nestaging                    # nestaging | openai | airobot-store | neprodai

# ── DynamoDB ─────────────────────────────────────────────────────────────────
initialize_tables=1                  # Set to 1 to auto-create tables on startup

# ── AWS (shared with KGE core) ───────────────────────────────────────────────
region_name=us-west-2
aws_access_key_id=                   # Your AWS access key
aws_secret_access_key=               # Your AWS secret key

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# IMPORTANT: neo4j_password MUST match your local Neo4j password.
# Test with: python -c "from neo4j import GraphDatabase; \
#   GraphDatabase.driver('bolt://localhost:7687',auth=('neo4j','YOUR_PASSWORD'))\
#   .verify_connectivity(); print('OK')"
neo4j_uri=bolt://localhost:7687
neo4j_username=neo4j
neo4j_password=                      # <-- fill in your actual Neo4j password
neo4j_database=neo4j

# ── LLM ──────────────────────────────────────────────────────────────────────
llm_type=openai
llm_name=gpt-4o
openai_api_key=                     # Your OpenAI API key
# openai_base_url=                  # Optional: custom endpoint (Azure, proxy, etc.)
# anthropic_api_key=                # Your Anthropic API key
# anthropic_base_url=               # Optional: custom endpoint
# ollama_host=http://localhost:11434

# ── Embeddings ───────────────────────────────────────────────────────────────
# embedding_provider=                # Defaults to llm_type if not set
embedding_model=text-embedding-3-small

# ── Cache ─────────────────────────────────────────────────────────────────────
cache_enabled=0

# ── Dual-Backend Selection (forwarded to KGE Config) ─────────────────────────
# db_backend: "dynamodb" (default) or "postgresql"
# When set to "postgresql", the PG_* keys below are used and DynamoDB table
# creation is skipped. Neo4j is always required regardless of backend.
# AWS credentials are still needed for Lambda dispatch and S3 file parsing.
db_backend=dynamodb

# PostgreSQL connection (used when db_backend=postgresql)
# Either DATABASE_URL or the PG_* keys below. When DATABASE_URL is set it wins
# (used by Alembic migrations; runtime Config uses individual PG_* keys).
# DATABASE_URL=postgresql+psycopg2://silvaengine:silvaengine@localhost:5432/silvaengine
PG_HOST=localhost
PG_PORT=5432
PG_USER=silvaengine
PG_PASSWORD=silvaengine
PG_DB=silvaengine
# Per-module PG table prefixes — each module gets its own prefix to avoid
# table-name collisions in shared databases.
KGE_PG_TABLE_PREFIX=kge_
RFQ_PG_TABLE_PREFIX=rfq_

# ── Default search query (used by call_search.py when --query is omitted) ────
DEFAULT_SEARCH_QUERY=FLIGHT-CDG-JFK-BUS
DEFAULT_SEARCH_MODE=text2cypher

# ── RFQ Engine ─────────────────────────────────────────────────────────────
# Used by call_inquire_catalog.py when --namespace / --query-text are omitted
INQUIRE_NAMESPACE=DEFAULT
INQUIRE_QUERY_TEXT=long haul international flights with meals included

# ── Cross-Module Routing ──────────────────────────────────────────────────
# functs_on_local: how modules call each other in-process.
# Override module/class names only if you renamed packages.
#FUNCTS_KGE_MODULE=knowledge_graph_engine
#FUNCTS_KGE_CLASS=KnowledgeGraphEngine
#FUNCTS_RFQ_MODULE=rfq_engine
#FUNCTS_RFQ_CLASS=RFQEngine
#FUNCTS_MCP_MODULE=mcp_daemon_engine
#FUNCTS_MCP_CLASS=MCPDaemonEngine

# ── MCP Daemon Engine (driven through the gateway) ────────────────────────
# These mirror ../mcp_daemon_engine/mcp_daemon_engine/tests/.env. The gateway
# forwards them to mcp_daemon_engine.handlers.config:Config.
MCP_TRANSPORT=sse                    # Forwarded as Config `transport`

# MCP tool-package staging (generateMcpPackageUploadUrl / processMcpPackage)
FUNCT_BUCKET_NAME=                   # S3 bucket for MCP tool packages
FUNCT_ZIP_PATH=/tmp/funct_zips       # Local zip staging path
FUNCT_EXTRACT_PATH=/tmp/functs       # Local package extraction path (must be importable)
# MCP_TEST_PACKAGE_ZIP=              # Path to a pre-built package ZIP for upload tests

# External MCP proxy tests (syncExternalMcpServer / external tool calls)
# MCP_TEST_EXTERNAL_BASE_URL=        # Reachable HTTP MCP server (JSON-RPC over POST)
# MCP_TEST_EXTERNAL_SERVER_NAME=test_external   # ^[A-Za-z][A-Za-z0-9_]*$
# MCP_TEST_EXTERNAL_BEARER=          # Bearer token forwarded upstream
# MCP_TEST_EXTERNAL_NAME_PREFIX=     # Prefix to avoid local name collisions
# MCP_TEST_EXTERNAL_TOOL_NAME=search_product   # Local tool name to invoke
# MCP_TEST_EXTERNAL_TOOL_QUERY=shirt # Free-text "query" argument

# ---------------------------------------------------------------------------
# Default test data values
# ---------------------------------------------------------------------------
# DEFAULT_AGENT_UUID=
# DEFAULT_USER_ID=test-user
# DEFAULT_UPDATED_BY=test-user
# cache_enabled=0

# ── AI Agent Core Engine (WebSocket streaming) ───────────────────────────────
# These are forwarded to ai_agent_core_engine.handlers.config:Config.
# The internal_mcp block is required for _get_agent() to fetch agent
# MCP server config at runtime.
#
# internal_mcp_base_url is the gateway base URL only. build_setting_from_env
# derives the MCP route as {internal_mcp_base_url}/{endpoint_id}/mcp. The
# ai_agent_core adds Part-Id from the active request tenant.
# If internal_mcp_bearer_token is blank, local auth can generate one from
# internal_mcp_token_username / internal_mcp_token_password. For non-local auth,
# the token is fetched from {internal_mcp_base_url}/auth/token.
# x-api-key is forwarded as a header to the MCP server.
#
# internal_mcp_base_url=http://localhost:8765
# internal_mcp_bearer_token=
# internal_mcp_token_username=admin
# internal_mcp_token_password=admin123
# x-api-key=
